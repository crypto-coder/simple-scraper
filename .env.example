CLOUD_LLM_URL=https://api.openai.com/v1
CLOUD_LLM_API_KEY=
LOCAL_LLM_MODEL=gemma4:e4b
OLLAMA_MODELS=./models
# Keep loaded models in memory (-1 = indefinitely; default 5m if unset)
OLLAMA_KEEP_ALIVE=-1
OUTPUT_FOLDER=./output

# n8n owner (auto-provisioned on startup; used for silent Workflow tab login)
N8N_OWNER_EMAIL=owner@simple-scraper.local
N8N_OWNER_PASSWORD=simple-scraper
N8N_OWNER_FIRST_NAME=Simple
N8N_OWNER_LAST_NAME=Scraper
# bcrypt hash of N8N_OWNER_PASSWORD — regenerate if you change the password.
# Use single quotes so Docker Compose does not treat $ as a variable.
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
N8N_OWNER_PASSWORD_HASH='$2b$10$HJzd2jAfW1u1rFG.ruW88uUm8vPkHFh8.Vb5txjxnMf3n.Zx1WRd2'
