CLOUD_LLM_URL=https://api.openai.com/v1
CLOUD_LLM_API_KEY=
LOCAL_LLM_MODEL=gemma4:e4b
OLLAMA_MODELS=./models
OLLAMA_KEEP_ALIVE=-1
OUTPUT_FOLDER=./output

# Browser URL when not using localhost (e.g. http://10.32.1.124:3000).
# Used for n8n editor links and webhooks. Leave unset for localhost.
PUBLIC_BASE_URL=
# Host:port n8n expects for Origin checks — must match what you type in the browser.
# Example: if PUBLIC_BASE_URL=http://10.32.1.124:3000 then N8N_HOST=10.32.1.124:3000
N8N_HOST=localhost:3000
# Edit config/n8n.env to change the n8n owner email/password/hash.
